# ThesisAI Backend — Environment Variables
# Copy this to .env and fill in your keys

# Google Gemini (primary fast model)
GEMINI_API_KEY=
MODEL_NAME=gemini-2.5-flash

# GitHub Models GPT (premium reasoning model)
GITHUB_MODELS_TOKEN=

# AI Router config
PRIMARY_MODEL=gemini
FALLBACK_MODEL=github

# Frontend URL for CORS (set in production)
FRONTEND_URL=http://localhost:3000
